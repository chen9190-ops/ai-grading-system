# Application
NODE_ENV=production
PORT=3000
HOSTNAME=127.0.0.1
AUTH_SECRET=replace_with_a_long_random_secret

# PostgreSQL: DATABASE_URL is preferred by Prisma and deployment scripts.
DATABASE_URL=postgresql://postgres:replace_me@127.0.0.1:5432/ai_grading?schema=public

# Optional alternative used by backup scripts only when DATABASE_URL is empty.
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=replace_me
DB_NAME=ai_grading
DB_SCHEMA=public

# Student grading Dify Workflow
DIFY_BASE_URL=https://api.dify.ai/v1
DIFY_API_KEY=

# Teacher report Dify Workflow
DIFY_TEACHER_REPORT_API_KEY=
DIFY_WORKFLOW_URL=https://api.dify.ai/v1/workflows/run

# Student mechanics assistant Chatflow
DIFY_ASSISTANT_API_KEY=
DIFY_ASSISTANT_URL=https://api.dify.ai/v1/chat-messages

# Practice/exam generator Chatflow
DIFY_PRACTICE_API_KEY=
DIFY_PRACTICE_URL=https://api.dify.ai/v1/chat-messages
