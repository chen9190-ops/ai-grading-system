generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  TEACHER
  ADMIN
}

enum AIConversationType {
  MECHANICS_ASSISTANT
  EXAM_GENERATOR
  TEACHING_REPORT
}

model User {
  id              String           @id @default(cuid())
  name            String
  email           String           @unique
  password        String
  role            UserRole
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  studentProfile  StudentProfile?
  teacherProfile  TeacherProfile?
  submissions     Submission[]
  examPapers      ExamPaper[]      @relation("ExamPaperTeacher")
  conversations   AIConversation[]
  teachingReports TeachingReport[] @relation("TeachingReportTeacher")

  @@index([role])
}

model StudentProfile {
  id        String @id @default(cuid())
  userId    String @unique
  studentId String @unique
  major     String
  className String
  user      User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([className])
}

model TeacherProfile {
  id         String @id @default(cuid())
  userId     String @unique
  teacherId  String @unique
  department String
  user       User   @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Course {
  id         String   @id @default(cuid())
  code       String   @unique
  name       String
  department String
  createdAt  DateTime @default(now())

  @@index([name])
}

model Submission {
  id               String   @id @default(cuid())
  requestId        String?
  workflowRunId    String?
  title            String?
  problemImageUrl  String?
  answerImageUrl   String?
  studentName      String   @default("匿名学生")
  studentId        String?
  courseName       String   @default("工程课程")
  className        String?
  problemImageName String
  answerImageName  String
  problemOcr       String?  @db.Text
  answerOcr        String?  @db.Text
  problemDiagram   String?  @db.Text
  answerDiagram    String?  @db.Text
  gradingResult    String   @db.Text
  score            Float?
  firstError       String?  @db.Text
  errorType        String?
  knowledgePoint   String?
  assignmentName   String?
  problemImages    Json?
  answerImages     Json?
  aiResult         Json?
  feedback         String?  @db.Text
  userId           String?
  student          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([studentId])
  @@index([studentName])
  @@index([errorType])
  @@index([knowledgePoint])
  @@index([userId])
  @@index([requestId])
  @@index([workflowRunId])
}

model ExamPaper {
  id            String   @id @default(cuid())
  teacherId     String
  courseName    String
  chapter       String
  difficulty    String
  questionCount Int
  questions     Json
  answer        Json
  createdAt     DateTime @default(now())
  teacher       User     @relation("ExamPaperTeacher", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, createdAt])
  @@index([courseName])
}

model AIConversation {
  id            String             @id @default(cuid())
  userId        String
  type          AIConversationType
  question      String             @db.Text
  answer        String             @db.Text
  knowledgeUsed Json?
  createdAt     DateTime           @default(now())
  user          User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, type, createdAt])
}

model TeachingReport {
  id         String   @id @default(cuid())
  teacherId  String
  courseName String
  inputData  Json
  report     Json
  createdAt  DateTime @default(now())
  teacher    User     @relation("TeachingReportTeacher", fields: [teacherId], references: [id], onDelete: Cascade)

  @@index([teacherId, createdAt])
  @@index([courseName])
}
