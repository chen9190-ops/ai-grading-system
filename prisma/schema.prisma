generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Submission {
  id               String   @id @default(cuid())
  studentName      String   @default("匿名学生")
  studentId        String?
  courseName       String   @default("工程课程")
  className        String?
  problemImageName String
  answerImageName  String
  problemOcr       String?  @db.Text
  answerOcr        String?  @db.Text
  problemDiagram   String?  @db.Text
  answerDiagram    String?  @db.Text
  gradingResult    String   @db.Text
  score            Float?
  firstError       String?  @db.Text
  errorType        String?
  knowledgePoint   String?
  createdAt        DateTime @default(now())

  @@index([createdAt])
  @@index([studentId])
  @@index([studentName])
  @@index([errorType])
  @@index([knowledgePoint])
}
